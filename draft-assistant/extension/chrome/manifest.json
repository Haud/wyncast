{
  "manifest_version": 3,
  "name": "Wyndham Draft Sync",
  "version": "0.1.0",
  "description": "Syncs ESPN fantasy baseball draft data to the draft assistant backend",
  "permissions": [
    "tabs",
    "activeTab",
    "offscreen"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://fantasy.espn.com/baseball/*"],
      "js": ["browser-polyfill.js", "content_scripts/espn.js"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; connect-src ws://localhost:* http://localhost:*; object-src 'self';"
  }
}
